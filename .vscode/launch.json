{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "create_agent - Nutria",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/create_agent.py",
            "console": "integratedTerminal",
            "args": ["new-agents/nutria/nutria-agent.json"]
        },
         {
            "name": "bibliosense - FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host", "0.0.0.0",
                "--port", "8080",
                "--reload"
            ],
            "jinja": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/bibliosense-agent"
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
         {
            "name": "index_chromadb_json - Bibliosense",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/bibliosense-agent/core/index_chromadb_json.py",
            "console": "integratedTerminal",
            "args": ["${workspaceFolder}/bibliosense-agent/knowledge-base/agent"]
        }
    ]
}