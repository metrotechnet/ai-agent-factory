    "version": "0.2.0",
    "configurations": [
        
         {
            "name": "IMX - NutrIA - FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host", "0.0.0.0",
                "--port", "8080",
                "--reload"
            ],
            "jinja": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/nutria-agent"
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {   
            "name": "IMX - Bibliosense - FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host", "0.0.0.0",
                "--port", "8080",
                "--reload"
            ],
            "jinja": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/bibliosense-agent"
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
         {
            "name": "IMX - Translator - FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host", "0.0.0.0",
