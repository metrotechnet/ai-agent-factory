# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).
#
# For more information, run:
#   $ gcloud topic gcloudignore
#
.gcloudignore
# If you would like to upload your .git directory, .gitignore file or files
# from your .gitignore file, remove the corresponding line below:
.git
.gitignore

# Python cache and build files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Environment and secrets (NEVER upload these)
.env
.env.local
.env.*.local
*-credentials.json
service-account*.json
credentials.json
token.json
client_secret*.json

# OS files
.DS_Store
Thumbs.db

# Temporary and backup files
*.old
*.tmp
*.bak
.backend-url.tmp

# Large media files (if not needed in deployment)
videos/

# Documentation (not needed in container)
*.md
!README.md

# IMPORTANT: Do NOT exclude knowledge-base JSON files
# These are needed for the application to run
# !knowledge-base/**/*.json is implicitly included by not excluding them
