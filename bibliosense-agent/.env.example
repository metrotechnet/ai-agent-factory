# ====================================
# API Keys
# ====================================
# OpenAI API key for GPT models
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API key for Gemini models
GEMINI_API_KEY=your-gemini-api-key-here

# ====================================
# Knowledge Base Configuration
# ====================================
# Name of the knowledge base folder to use (e.g., 'agent', 'nutria', 'bibliosense')
# This determines which knowledge base in the knowledge-base/ directory to load
KNOWLEDGE_BASE=agent

# ====================================
# Google Cloud Platform (GCP) Configuration
# ====================================
# GCP Project ID where resources will be deployed
GCP_PROJECT_ID=multi-agent-487816

# GCP region for deployment (e.g., us-central1, us-east4, europe-west1)
GCP_REGION=us-east4

# Cloud Run service name
GCP_SERVICE_NAME=imx-multi-agent

# Docker image name for Cloud Run (format: gcr.io/project-id/image-name)
GCP_IMAGE_NAME=gcr.io/multi-agent-487816/imx-multi-agent

# Memory allocation for Cloud Run service (e.g., 512Mi, 1Gi, 2Gi)
CLOUD_RUN_MEMORY=1Gi

# Timeout in seconds for Cloud Run service (max 3600)
CLOUD_RUN_TIMEOUT=300

# ====================================
# Google Drive Integration
# ====================================
# Google Drive folder ID for knowledge base sync
GDRIVE_FOLDER_ID=your-google-drive-folder-id


# ====================================
# Frontend Configuration
# ====================================
# Backend API URL for frontend deployment (used by Firebase hosting)
# For local development: http://localhost:8080
# For production: https://your-service-name-hash-region.run.app
BACKEND_URL=http://localhost:8080

# Firebase project ID for frontend hosting
FIREBASE_PROJECT_ID=your-firebase-project-id

# Additional CORS origins (optional, comma-separated)
# Use this to add custom domains that should be allowed to access the API
# Example: ADDITIONAL_CORS_ORIGINS=https://custom-domain.com,https://another-domain.com
ADDITIONAL_CORS_ORIGINS=


