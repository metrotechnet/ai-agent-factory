# ====================================
# API Keys
# ====================================
# Vercel AI Gateway API key
# Get your key at: https://vercel.com/dashboard/ai-gateway/api-keys
# See: https://vercel.com/docs/ai-gateway
# Use provider/model format for model names (e.g., openai/gpt-4o-mini, google/gemini-2.0-flash)
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-api-key-here

# ====================================
# Knowledge Base Configuration
# ====================================
# Name of the knowledge base folder to use (e.g., 'agent', 'nutria', 'bibliosense')
# This determines which knowledge base in the knowledge-base/ directory to load
KNOWLEDGE_BASE=agent

# ====================================
# Google Cloud Platform (GCP) Configuration
# ====================================
# GCP Project ID where resources will be deployed
GCP_PROJECT_ID=your-project-id

# Cloud Run Service Configuration
CLOUD_RUN_SERVICE_NAME=imx-translator
CLOUD_RUN_REGION=us-east4
CLOUD_RUN_MEMORY=2Gi
CLOUD_RUN_CPU=2
CLOUD_RUN_MAX_INSTANCES=10
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_TIMEOUT=300

# ====================================
# Google Cloud Storage Configuration
# ====================================
# GCS bucket name for storing knowledge base files
GCS_BUCKET_NAME=your-bucket-name

# ====================================
# Google Drive Configuration (Optional)
# ====================================
# Google Drive folder ID to sync knowledge base from
# Used by update_gdrive.py script to automatically download files from Google Drive
GDRIVE_FOLDER_ID=your-google-drive-folder-id

# Path to service account JSON key file for Google Drive API access
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# ====================================
# ChromaDB Configuration
# ====================================
# Path to the ChromaDB database directory
CHROMADB_PATH=./chroma_db

# ChromaDB collection name
CHROMADB_COLLECTION=documents

# ====================================
# Query Configuration
# ====================================
# Maximum number of documents to return from similarity search
MAX_RESULTS=5

# Minimum similarity score threshold (0.0 to 1.0)
MIN_SIMILARITY_SCORE=0.3

# ====================================
# Rate Limiting Configuration
# ====================================
# Enable rate limiting for API endpoints
RATE_LIMIT_ENABLED=true

# Number of allowed requests per time period (per IP)
RATE_LIMIT_REQUESTS=20

# Time period for rate limiting in seconds
RATE_LIMIT_PERIOD=60

# ====================================
# Firebase Configuration
# ====================================
# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase API Key (public)
FIREBASE_API_KEY=your-firebase-api-key

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# Firebase App ID
FIREBASE_APP_ID=1:your-app-id:web:your-web-app-id

# Firebase Measurement ID (optional)
FIREBASE_MEASUREMENT_ID=G-YOUR-MEASUREMENT-ID

# reCAPTCHA v3 Site Key (public)
RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# Enable Firebase App Check token verification
APP_CHECK_ENABLED=true

# Firebase App Check Debug Token (for local development only)
APP_CHECK_DEBUG_TOKEN=your-debug-token-here
